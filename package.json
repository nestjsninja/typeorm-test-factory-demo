{
  "name": "typeorm-test-factory-demo",
  "version": "0.0.0",
  "private": true,
  "description": "A real NestJS app consuming typeorm-test-factory from npm",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "ts-node src/main.ts",
    "start:prod": "node dist/main.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sql.js": "^1.10.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/sql.js": "^1.4.9",
    "@types/supertest": "^6.0.0",
    "jest": "^29.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "typeorm-test-factory": "^0.2.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "rootDir": ".",
    "roots": ["<rootDir>/src", "<rootDir>/test"],
    "testRegex": ".*\\.(int-spec|e2e-spec|spec)\\.ts$",
    "moduleFileExtensions": ["ts", "js", "json"]
  }
}
